{
  "name": "astro-dx-root",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^1.9.0"
  },
  "scripts": {
    "dev": "pnpm --filter astro-dx-demo dev",
    "build": "pnpm --filter astro-dx build && pnpm --filter astro-dx-demo build",
    "build:lib": "pnpm --filter astro-dx build",
    "test": "pnpm --filter astro-dx test",
    "test:e2e": "pnpm --filter astro-dx-demo test:e2e",
    "lint": "biome check .",
    "format": "biome format --write ."
  }
}
