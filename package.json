{
  "name": "astro-dx-root",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@changesets/cli": "^2.30.0"
  },
  "scripts": {
    "dev": "pnpm run build:packages && pnpm --filter astro-dx-demo dev",
    "build": "pnpm build:packages && pnpm --filter astro-dx-demo build",
    "build:packages": "pnpm --filter './packages/*' build",
    "build:demo": "pnpm --filter astro-dx-demo... build",
    "test": "pnpm --filter './packages/*' --if-present test",
    "test:e2e": "pnpm --filter astro-dx-demo test:e2e",
    "test:e2e:ui": "pnpm --filter astro-dx-demo test:e2e:ui",
    "deploy:demo:local": "pnpm build:demo && pnpm --filter astro-dx-demo preview:cf",
    "deploy:demo": "pnpm build:demo && pnpm --filter astro-dx-demo deploy:cf",
    "lint": "biome check .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build:packages && changeset publish",
    "changeset:status": "changeset status"
  }
}
