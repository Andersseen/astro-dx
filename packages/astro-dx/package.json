{
  "name": "astro-dx",
  "version": "0.1.0",
  "description": "Angular-inspired signals, DOM bindings and services for Astro client-side scripting",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dom": {
      "import": "./dist/dom/index.js",
      "types": "./dist/dom/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "nanostores": "^0.11.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "jsdom": "^24.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
