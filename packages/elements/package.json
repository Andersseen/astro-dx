{
  "name": "@astro-dx/elements",
  "version": "0.1.0",
  "description": "Reactive custom elements for Astro - dx-if, dx-show, dx-for as web components",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@astro-dx/core": "*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "happy-dom": "^14.0.0"
  }
}
