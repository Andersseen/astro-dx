{
  "name": "astro-dx-demo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:cf": "wrangler pages dev dist",
    "deploy:cf": "wrangler pages deploy dist --project-name astro-dx-demo --branch main",
    "test:e2e": "playwright test --config=playwright/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright/playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=playwright/playwright.config.ts --debug"
  },
  "dependencies": {
    "@andersseen/icon": "latest",
    "@andersseen/layout": "latest",
    "@andersseen/motion": "latest",
    "@andersseen/web-components": "latest",
    "@astro-dx/attributes": "workspace:*",
    "@astro-dx/core": "workspace:*",
    "@astro-dx/dom": "workspace:*",
    "@astro-dx/elements": "workspace:*",
    "@astro-dx/events": "workspace:*",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "astro": "^5.0.0",
    "codemirror": "^6.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@tailwindcss/vite": "^4.2.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.5.0",
    "wrangler": "^4.8.0"
  }
}
