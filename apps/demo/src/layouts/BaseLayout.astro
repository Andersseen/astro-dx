---
import '../styles/global.css';
import AppFooter from '../components/layout/AppFooter.astro';
import AppNavbar from '../components/layout/AppNavbar.astro';
import AppSEO from '../components/layout/AppSEO.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const {
  title,
  description = 'Angular-inspired DX for Astro — community library',
  image,
} = Astro.props;
const pathname = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <AppSEO {title} {description} {image} />
  </head>
  <body class="app-shell">
    <div class="ambient-glow ambient-glow-a"></div>
    <div class="ambient-glow ambient-glow-b"></div>

    <AppNavbar currentPath={pathname} />

    <main class="relative z-10">
      <slot />
    </main>

    <AppFooter />

    <script>
      import '../scripts/bootstrap.ts';
    </script>

  </body>
</html>
