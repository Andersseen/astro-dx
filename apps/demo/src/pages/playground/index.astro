---
import Playground from '../../components/playground/Playground.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { signalsPlayground } from '../../snippets/playground/signals.ts';
import { domPlayground } from '../../snippets/playground/dom.ts';
import { servicesPlayground } from '../../snippets/playground/services.ts';
import { attributesPlayground } from '../../snippets/playground/attributes.ts';
import { eventsPlayground } from '../../snippets/playground/events.ts';

const playgrounds = {
  signals:    { title: 'Signals',    desc: 'signal(), computed(), effect()', badge: '@astro-dx/core',       files: signalsPlayground },
  services:   { title: 'Services',   desc: 'Singleton state across islands',  badge: '@astro-dx/core',       files: servicesPlayground },
  dom:        { title: 'DOM',        desc: 'getElement(), text(), cls()',      badge: '@astro-dx/dom',        files: domPlayground },
  events:     { title: 'Events',     desc: 'onClick, onInput, onKey, onHover', badge: '@astro-dx/events',     files: eventsPlayground },
  attributes: { title: 'Directives', desc: 'dx-if, dx-show, dx-for',          badge: '@astro-dx/attributes', files: attributesPlayground },
};

const entries = Object.entries(playgrounds);
---
<BaseLayout title="Playground">
  <div class="playground-page">
    <!-- Sidebar -->
    <and-sidebar
      id="playground-sidebar"
      class="playground-sidebar"
      variant="default"
      item-variant="filled"
      mobile-collapse
    >
      <span slot="header" class="playground-sidebar-header">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16"/></svg>
        Playground
      </span>
    </and-sidebar>

    <!-- Content area -->
    <main class="playground-content">
      {entries.map(([key, pg], i) => (
        <div
          class={`playground-section ${i === 0 ? 'active' : ''}`}
          data-section={key}
        >
          <div class="playground-section-header">
            <div>
              <and-badge variant="outline" class="playground-badge">{pg.badge}</and-badge>
              <h1 class="playground-section-title">{pg.title}</h1>
              <p class="playground-section-desc">{pg.desc}</p>
            </div>
          </div>
          <Playground id={key} files={pg.files} height={420} />
        </div>
      ))}
    </main>
  </div>
</BaseLayout>

<script>
  const SIDEBAR_ITEMS = [
    { id: 'signals',    label: 'Signals',    icon: 'zap' },
    { id: 'services',   label: 'Services',   icon: 'layers' },
    { id: 'dom',        label: 'DOM',        icon: 'mouse-pointer' },
    { id: 'events',     label: 'Events',     icon: 'pointer' },
    { id: 'attributes', label: 'Directives', icon: 'code' },
  ];

  const sidebar = document.getElementById('playground-sidebar') as any;
  sidebar.items = SIDEBAR_ITEMS;
  sidebar.activeItem = 'signals';

  const sections = document.querySelectorAll<HTMLElement>('.playground-section');

  function showSection(id: string) {
    sections.forEach(s => {
      s.classList.toggle('active', s.dataset.section === id);
    });
  }

  sidebar.addEventListener('andSidebarItemClick', (e: CustomEvent<string>) => {
    sidebar.activeItem = e.detail;
    showSection(e.detail);
  });
</script>

<style>
  .playground-page {
    display: flex;
    height: calc(100vh - var(--navbar-height, 56px));
    overflow: hidden;
  }

  .playground-sidebar {
    flex-shrink: 0;
    border-right: 1px solid hsl(var(--border));
  }

  .playground-sidebar-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .playground-content {
    flex: 1;
    overflow-y: auto;
    padding: 1.5rem 2rem;
  }

  @media (max-width: 767px) {
    .playground-content {
      padding: 1rem;
    }
  }

  .playground-section {
    display: none;
  }
  .playground-section.active {
    display: block;
  }

  .playground-section-header {
    margin-bottom: 1.25rem;
  }

  .playground-badge {
    margin-bottom: 0.5rem;
  }

  .playground-section-title {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0.375rem 0 0;
    font-family: var(--font-sans, system-ui);
  }

  .playground-section-desc {
    font-size: 0.875rem;
    opacity: 0.6;
    margin: 0.25rem 0 0;
  }
</style>
