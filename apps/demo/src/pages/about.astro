---
import BaseLayout from '../layouts/BaseLayout.astro';
import { systemPrompt, astroDxContext, coreContext, domContext, eventsContext, attributesContext } from '../snippets/prompts';
---
<BaseLayout title="About">
  <section class="section">
    <div class="container-sm flex flex-col gap-10">

      <!-- Header -->
      <div class="flex flex-col gap-3">
        <span class="text-xs uppercase tracking-[0.08em] opacity-50">About</span>
        <h1 class="m-0 font-sans text-4xl font-extrabold">What is astro-dx?</h1>
      </div>

      <!-- Disclaimer -->
      <div class="surface-theme border-theme rounded-lg border px-4 py-3.5 text-sm leading-7">
        <strong class="text-theme-accent">Community library</strong> —
        astro-dx is not affiliated with, endorsed by, or part of the official Astro project.
      </div>

      <!-- Content -->
      <div class="flex flex-col gap-4">
        <p class="m-0 text-[0.9375rem] leading-7 opacity-75">
          Astro is great for content-focused sites with zero JS by default.
          But when you need client-side interactivity across islands,
          the DX gets rough — raw nanostores, manual querySelector, no cleanup, no structure.
        </p>
        <p class="m-0 text-[0.9375rem] leading-7 opacity-75">
          astro-dx brings the patterns Angular developers know —
          signals, computed values, singleton services, declarative DOM bindings —
          to Astro client scripts. No compiler, no framework, just ergonomic TypeScript.
        </p>
      </div>

      <!-- FAQ -->
      <div class="flex flex-col">
        <and-accordion>
          <and-accordion-item>
            <span slot="header">Why not just use Preact or Vue islands?</span>
            <p slot="content" class="m-0 text-sm leading-7 opacity-65">
              You can — and sometimes you should. astro-dx fills the gap for components
              that need interactivity but not a full framework. Less JS, more native.
            </p>
          </and-accordion-item>
          <and-accordion-item>
            <span slot="header">Why not Alpine.js?</span>
            <p slot="content" class="m-0 text-sm leading-7 opacity-65">
              Alpine uses eval() for HTML expressions. astro-dx keeps all logic
              in TypeScript where you have type safety and editor autocompletion.
            </p>
          </and-accordion-item>
          <and-accordion-item>
            <span slot="header">Does it work with Cloudflare Pages?</span>
            <p slot="content" class="m-0 text-sm leading-7 opacity-65">
              Yes. astro-dx is fully static — no server runtime needed.
              Built specifically with Cloudflare + Astro in mind.
            </p>
          </and-accordion-item>
          <and-accordion-item>
            <span slot="header">Does it support Astro ViewTransitions?</span>
            <p slot="content" class="m-0 text-sm leading-7 opacity-65">
              Yes. Use onPageLoad() and onBeforeSwap() from @astro-dx/core
              to initialize and clean up safely across navigations.
            </p>
          </and-accordion-item>
        </and-accordion>
      </div>

      <!-- Agent Prompts -->
      <div class="flex flex-col gap-4 mt-8">
        <h2 class="m-0 font-sans text-2xl font-extrabold">AI Agent Prompts</h2>
        <p class="m-0 text-[0.9375rem] leading-7 opacity-75">
          These libraries are new and not yet covered in standard LLM training data.
          Copy these context prompts into your AI agent (Claude, ChatGPT, Cursor, etc.)
          so it knows exactly how to use astro-dx.
        </p>

        <and-tabs default-value="system">
          <and-tabs-list>
            <and-tabs-trigger value="system">Agent</and-tabs-trigger>
            <and-tabs-trigger value="overview">Overview</and-tabs-trigger>
            <and-tabs-trigger value="core">Core</and-tabs-trigger>
            <and-tabs-trigger value="dom">DOM</and-tabs-trigger>
            <and-tabs-trigger value="events">Events</and-tabs-trigger>
            <and-tabs-trigger value="attributes">Directives</and-tabs-trigger>
          </and-tabs-list>

          <and-tabs-content value="system">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{systemPrompt}</code></pre>
            </div>
          </and-tabs-content>

          <and-tabs-content value="overview">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{astroDxContext}</code></pre>
            </div>
          </and-tabs-content>

          <and-tabs-content value="core">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{coreContext}</code></pre>
            </div>
          </and-tabs-content>

          <and-tabs-content value="dom">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{domContext}</code></pre>
            </div>
          </and-tabs-content>

          <and-tabs-content value="events">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{eventsContext}</code></pre>
            </div>
          </and-tabs-content>

          <and-tabs-content value="attributes">
            <div class="prompt-panel">
              <pre class="prompt-code"><code>{attributesContext}</code></pre>
            </div>
          </and-tabs-content>
        </and-tabs>
      </div>

    </div>
  </section>
</BaseLayout>

<style>
  .prompt-panel {
    height: 520px;
    overflow-y: auto;
    margin-top: 1rem;
    border-radius: 0.5rem;
    border: 1px solid hsl(var(--border));
    background: hsl(240 10% 4%);
  }

  .prompt-code {
    margin: 0;
    padding: 1.25rem;
    font-size: 0.8125rem;
    line-height: 1.7;
    color: hsl(0 0% 90%);
    white-space: pre-wrap;
    word-break: break-word;
  }

  /* Scrollbar styling */
  .prompt-panel::-webkit-scrollbar {
    width: 6px;
  }
  .prompt-panel::-webkit-scrollbar-track {
    background: transparent;
  }
  .prompt-panel::-webkit-scrollbar-thumb {
    background: hsl(var(--muted));
    border-radius: 3px;
  }
</style>
