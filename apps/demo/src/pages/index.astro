---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">

  <!-- Hero -->
  <section class="section flex min-h-[88vh] items-center">
    <div class="container flex flex-col items-center gap-8 text-center">

      <!-- Disclaimer -->
      <span class="rounded-full border border-white/15 px-3 py-1 text-xs opacity-50">
        Community library · Not official Astro
      </span>

      <!-- Headline -->
      <div class="flex max-w-[700px] flex-col gap-4">
        <h1 class="m-0 font-sans text-[clamp(2.5rem,6vw,4rem)] font-extrabold leading-[1.1]">
          Angular-inspired DX<br/>
          for <span class="text-orange-400">Astro</span>
        </h1>
        <p class="mx-auto m-0 max-w-[560px] text-lg leading-[1.7] opacity-60">
          Signals, services, DOM bindings and reactive templates —
          without leaving Astro. Built on nanostores.
        </p>
      </div>

      <!-- Install command -->
      <div class="flex items-center gap-3 rounded-xl border border-white/10 bg-white/5 px-5 py-2.5">
        <span class="font-mono text-sm opacity-40">$</span>
        <span class="font-mono text-sm">npx @astro-dx/init</span>
        <button
          id="btn-copy"
          title="Copy"
          class="flex items-center p-1 text-inherit opacity-40 transition-opacity hover:opacity-100"
        >
          <and-icon name="copy" size="14"></and-icon>
        </button>
      </div>

      <!-- CTA buttons -->
      <div class="flex flex-wrap justify-center gap-3">
        <and-button variant="default" href="/docs/installation">
          Get started
        </and-button>
        <and-button variant="outline" href="/demo">
          See demos
        </and-button>
      </div>

      <!-- Feature grid -->
      <div class="mt-8 grid w-full max-w-[900px] grid-cols-[repeat(auto-fit,minmax(200px,1fr))] gap-4">

        <div class="flex flex-col gap-2.5 rounded-xl border border-white/10 bg-white/5 p-5 text-left">
          <and-icon name="zap" size="20" class="text-orange-400"></and-icon>
          <strong class="text-[0.9rem]">Signals</strong>
          <span class="text-xs leading-6 opacity-55">signal(), computed(), effect() — Angular 20+ API</span>
        </div>

        <div class="flex flex-col gap-2.5 rounded-xl border border-white/10 bg-white/5 p-5 text-left">
          <and-icon name="layers" size="20" class="text-orange-400"></and-icon>
          <strong class="text-[0.9rem]">Services</strong>
          <span class="text-xs leading-6 opacity-55">Singleton classes. Share state across islands.</span>
        </div>

        <div class="flex flex-col gap-2.5 rounded-xl border border-white/10 bg-white/5 p-5 text-left">
          <and-icon name="mouse-pointer" size="20" class="text-orange-400"></and-icon>
          <strong class="text-[0.9rem]">DOM bindings</strong>
          <span class="text-xs leading-6 opacity-55">getElement(), text(), attr() — no querySelector</span>
        </div>

        <div class="flex flex-col gap-2.5 rounded-xl border border-white/10 bg-white/5 p-5 text-left">
          <and-icon name="code" size="20" class="text-orange-400"></and-icon>
          <strong class="text-[0.9rem]">Templates</strong>
          <span class="text-xs leading-6 opacity-55">dx-if, dx-show, dx-for — attributes or elements</span>
        </div>

      </div>

    </div>
  </section>

  <script>
    import { getElement } from '@astro-dx/dom';

    getElement<HTMLButtonElement>('#btn-copy').on('click', () => {
      navigator.clipboard.writeText('npx @astro-dx/init');
    });
  </script>

</BaseLayout>
