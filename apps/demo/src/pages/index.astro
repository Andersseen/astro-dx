---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">
  <section class="min-h-[90vh] px-6 py-32">
    <div and-layout="vertical gap:xl align:center" class="max-w-4xl mx-auto text-center">

      <and-badge
        variant="outline"
        and-motion="fade-in"
        and-motion-trigger="enter"
      >
        Community library · Not official Astro
      </and-badge>

      <div
        and-layout="vertical gap:md align:center"
        and-motion="slide-in-up"
        and-motion-trigger="enter"
        and-motion-delay="100ms"
      >
        <h1 and-text="h1 weight:bold">
          Angular-inspired DX<br/>for <span class="text-amber-400">Astro</span>
        </h1>
        <p and-text="p-lg" class="max-w-2xl opacity-70">
          Signals, services, DOM bindings and reactive templates —
          without leaving Astro. Built on nanostores.
        </p>
      </div>

      <div
        and-motion="slide-in-up"
        and-motion-trigger="enter"
        and-motion-delay="200ms"
        class="flex items-center gap-3 px-5 py-3 rounded-xl border border-white/10 bg-white/5 font-mono text-sm"
      >
        <span class="opacity-40">$</span>
        <span>npx @astro-dx/init</span>
        <and-button variant="ghost" size="sm" id="btn-copy" class="ml-2 opacity-50 hover:opacity-100 transition-opacity">
          <and-icon name="copy" size="14"></and-icon>
        </and-button>
      </div>

      <div
        and-layout="horizontal gap:md align:center"
        and-motion="slide-in-up"
        and-motion-trigger="enter"
        and-motion-delay="300ms"
      >
        <and-button variant="default" href="/docs/installation">
          Get started
        </and-button>
        <and-button variant="outline" href="/demo">
          See demos
        </and-button>
      </div>

      <div
        and-layout="grid cols:1 cols@md:2 cols@lg:4 gap:md"
        class="w-full mt-8"
        and-motion="fade-in"
        and-motion-trigger="enter"
        and-motion-delay="400ms"
      >
        <and-card>
          <div and-layout="vertical gap:sm" class="p-5">
            <and-icon name="zap" size="22" class="text-amber-400"></and-icon>
            <h3 and-text="h6 weight:bold">Signals</h3>
            <p and-text="p-sm" class="opacity-60">
              signal(), computed(), effect() — Angular 20+ API
            </p>
          </div>
        </and-card>
        <and-card>
          <div and-layout="vertical gap:sm" class="p-5">
            <and-icon name="layers" size="22" class="text-amber-400"></and-icon>
            <h3 and-text="h6 weight:bold">Services</h3>
            <p and-text="p-sm" class="opacity-60">
              Singleton classes. Share state across any island.
            </p>
          </div>
        </and-card>
        <and-card>
          <div and-layout="vertical gap:sm" class="p-5">
            <and-icon name="mouse-pointer" size="22" class="text-amber-400"></and-icon>
            <h3 and-text="h6 weight:bold">DOM bindings</h3>
            <p and-text="p-sm" class="opacity-60">
              getElement(), text(), attr() — no querySelector
            </p>
          </div>
        </and-card>
        <and-card>
          <div and-layout="vertical gap:sm" class="p-5">
            <and-icon name="code" size="22" class="text-amber-400"></and-icon>
            <h3 and-text="h6 weight:bold">Templates</h3>
            <p and-text="p-sm" class="opacity-60">
              dx-if, dx-show, dx-for as attributes or elements
            </p>
          </div>
        </and-card>
      </div>

    </div>
  </section>

  <script>
    import { getElement } from '@astro-dx/dom';

    getElement('#btn-copy').on('click', () => {
      navigator.clipboard.writeText('npx @astro-dx/init');
    });
  </script>

</BaseLayout>