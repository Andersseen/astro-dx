---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Home">
  <section class="py-14 md:py-20 lg:py-24">
    <div
      class="mx-auto grid max-w-3xl gap-5 text-center"
      and-motion="fade-in"
      and-motion-trigger="enter"
    >
      <div class="text-primary text-xs font-extrabold uppercase tracking-[0.2em]">Community library · Not official Astro</div>
      <h1 class="text-balance">
        Angular-inspired DX for <span class="text-primary-600">Astro</span>
      </h1>
      <p class="mx-auto max-w-2xl text-base text-muted-foreground md:text-lg">
        Signals, services, DOM bindings and reactive templates without leaving Astro.
        Built on nanostores.
      </p>
    </div>

    <div
      class="mx-auto mt-5 flex w-fit items-center gap-2 rounded-full border border-border bg-card px-4 py-2 text-sm text-card-foreground shadow-sm max-sm:w-full max-sm:justify-center max-sm:rounded-xl"
      and-motion="slide-in-up"
      and-motion-trigger="enter"
      and-motion-delay="120ms"
    >
      <and-icon name="terminal" size="16"></and-icon>
      <span>$</span>
      <span>npx @astro-dx/init</span>
      <and-button variant="ghost" size="sm" id="btn-copy" aria-label="Copy install command">
        <and-icon name="copy" size="14"></and-icon>
      </and-button>
    </div>

    <div
      class="mt-5 flex flex-wrap items-center justify-center gap-3"
      and-motion="slide-in-up"
      and-motion-trigger="enter"
      and-motion-delay="220ms"
    >
      <and-button variant="default" href="/docs">Get started</and-button>
      <and-button variant="outline" href="/demo">See demos</and-button>
    </div>

    <div
      class="mt-10 grid gap-4 sm:grid-cols-2 xl:grid-cols-4"
      and-motion="fade-in"
      and-motion-trigger="enter"
      and-motion-delay="300ms"
    >
      {[
        { icon: 'zap', title: 'Signals', desc: 'signal(), computed(), effect() with an Angular-like mental model.' },
        { icon: 'layers', title: 'Services', desc: 'Singleton classes to share state across Astro islands.' },
        { icon: 'code', title: 'DOM bindings', desc: 'text(), attr(), cls() and event helpers without querySelector noise.' },
        { icon: 'component', title: 'Reactive templates', desc: 'dx-if, dx-show and dx-for as attributes or custom elements.' },
      ].map((f, index) => (
        <article class="h-full" and-motion="slide-in-up" and-motion-trigger="enter" and-motion-delay={`${260 + index * 70}ms`}>
          <div class="h-full rounded-xl border border-border bg-card shadow-sm transition-transform duration-200 hover:-translate-y-0.5 hover:border-primary-300">
            <div class="grid gap-3 p-5">
              <and-icon name={f.icon} size="24" class="text-primary-600"></and-icon>
              <h3 class="text-lg font-semibold tracking-tight text-card-foreground">{f.title}</h3>
              <p class="text-sm leading-relaxed text-muted-foreground">{f.desc}</p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <script>
    import { getElement } from '@astro-dx/dom';

    const btnCopy = getElement<HTMLButtonElement>('#btn-copy');
    btnCopy.on('click', () => {
      navigator.clipboard.writeText('npx @astro-dx/init');
    });
  </script>

</BaseLayout>