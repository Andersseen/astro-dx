---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Demos">
  <section class="max-w-4xl mx-auto px-6 py-24">
    <div and-layout="vertical gap:xl">

      <div and-layout="vertical gap:sm">
        <and-badge variant="outline" class="w-fit">Demos</and-badge>
        <h1 and-text="h2 weight:bold">Live demos</h1>
        <p and-text="p" class="opacity-70">Every demo is real. No mocks.</p>
      </div>

      <div and-layout="grid cols:1 cols@md:2 gap:lg">
        {([
          {
            href: '/demo/signals',
            title: 'Signals',
            desc: 'signal(), computed(), effect()',
            icon: 'zap',
            badge: '@astro-dx/core'
          },
          {
            href: '/demo/services',
            title: 'Services',
            desc: 'Singleton services. Cross-island state.',
            icon: 'layers',
            badge: '@astro-dx/core'
          },
          {
            href: '/demo/dom',
            title: 'DOM bindings',
            desc: 'getElement(), model(), style()',
            icon: 'mouse-pointer',
            badge: '@astro-dx/dom'
          },
          {
            href: '/demo/attributes',
            title: 'Attributes',
            desc: 'dx-if, dx-show, dx-for, dx-model',
            icon: 'code',
            badge: '@astro-dx/attributes'
          },
          {
            href: '/demo/elements',
            title: 'Elements',
            desc: 'dx-show, dx-if, dx-for as custom elements',
            icon: 'box',
            badge: '@astro-dx/elements'
          },
          {
            href: '/demo/events',
            title: 'Events',
            desc: 'onInput, onSubmit, onHover, onFocus, onResize',
            icon: 'mouse-pointer',
            badge: '@astro-dx/events'
          },
        ] as const).map(d => (
          <a
            href={d.href}
            style="text-decoration:none"
            and-motion="slide-in-up"
            and-motion-trigger="enter"
          >
            <and-card class="h-full cursor-pointer">
              <div and-layout="vertical gap:sm" class="p-6">
                <div and-layout="horizontal gap:sm align:center justify:between">
                  <and-icon name={d.icon} size="20" class="text-amber-400"></and-icon>
                  <and-badge variant="outline">{d.badge}</and-badge>
                </div>
                <h3 and-text="h6 weight:bold">{d.title}</h3>
                <p and-text="p-sm" class="opacity-60">{d.desc}</p>
              </div>
            </and-card>
          </a>
        ))}
      </div>

    </div>
  </section>
</BaseLayout>
