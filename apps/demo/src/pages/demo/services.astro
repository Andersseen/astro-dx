---
<BaseLayout title="Test de Services">
  <section and-layout="vertical gap:xl" class="max-w-4xl mx-auto px-6 py-24">

    <div and-layout="vertical gap:sm">
      <and-badge variant="outline" class="w-fit">TEST DE AISLAMIENTO</and-badge>
      <h1 and-text="h2 weight:bold">Detector de Mentiras (Global vs Local)</h1>
      <p and-text="p" class="opacity-70">
        Prueba pura de inyección. Abre la consola de desarrollo (F12) para ver los resultados.
      </p>
    </div>

    <div and-layout="grid cols:1 cols@md:2 gap:lg">
      
      <div style="padding: 1.5rem; border: 1px solid hsl(var(--border)); border-radius: 12px; background: hsl(var(--card));">
        <h3 and-text="h6 weight:bold" style="color: hsl(var(--primary))">Registro Global</h3>
        <div id="txt-global" style="font-size: 4rem; font-weight: 800; margin: 1rem 0;">0</div>
        <and-button id="btn-global" variant="primary" class="w-full">Global +1</and-button>
      </div>

      <div style="padding: 1.5rem; border: 1px dashed hsl(var(--border)); border-radius: 12px; background: hsl(var(--muted));">
        <h3 and-text="h6 weight:bold" class="opacity-70">Registro Local (Aislado)</h3>
        <div id="txt-local" style="font-size: 4rem; font-weight: 800; margin: 1rem 0;">0</div>
        <and-button id="btn-local" variant="outline" class="w-full">Local +1</and-button>
      </div>

    </div>

    </section>

  <script>
    import { signal, GlobalRegistry, createLocalRegistry } from '@astro-dx/core';

    // 1. CLASE DE PRUEBA BLINDADA
    class TestCounterService {
      count;
      constructor() {
        this.count = signal(0);
      }
    }

    // 2. INYECCIÓN
    const globalCounter = GlobalRegistry.inject(TestCounterService);
    
    const localRegistry = createLocalRegistry();
    const localCounter = localRegistry.inject(TestCounterService);

    // 🚨 3. EL DETECTOR DE MENTIRAS (Revisa la consola) 🚨
    console.log("%c=== RESULTADOS DEL TEST ===", "color: #00ff00; font-weight: bold; font-size: 14px;");
    console.log("1. ¿Son exactamente la misma CLASE?:", globalCounter === localCounter);
    console.log("2. ¿Son exactamente el mismo SIGNAL?:", globalCounter.count === localCounter.count);
    
    if (globalCounter === localCounter) {
      console.warn("⚠️ ALERTA: El Registry está devolviendo la misma instancia. Revisa si usaste registerShared() en algún lado.");
    } else {
      console.log("✅ ÉXITO: Las instancias están correctamente separadas en memoria.");
    }

    // 4. BINDING DE UI
    const txtGlobal = document.getElementById('txt-global');
    const btnGlobal = document.getElementById('btn-global');
    const txtLocal = document.getElementById('txt-local');
    const btnLocal = document.getElementById('btn-local');

    // Suscripciones
    globalCounter.count.subscribe(v => { if (txtGlobal) txtGlobal.innerText = String(v); });
    localCounter.count.subscribe(v => { if (txtLocal) txtLocal.innerText = String(v); });

    // Eventos
    btnGlobal?.addEventListener('click', () => {
      globalCounter.count.set(globalCounter.count.peek() + 1);
    });
    
    btnLocal?.addEventListener('click', () => {
      localCounter.count.set(localCounter.count.peek() + 1);
    });

    // ==========================================
    // 🗄️ SCRIPT ORIGINAL (COMENTADO)
    // ==========================================
    /*
    import { inject } from '@astro-dx/core';
    import { getElement, getElements } from '@astro-dx/dom';
    import { onClick } from '@astro-dx/events';
    import { ShopServiceClass } from '../../services/shop.service';

    const cart = inject(ShopServiceClass);

    // Island A — product buttons
    const productBtns = getElements<HTMLButtonElement>('.product-btn');
    for (const btn of productBtns) {
      onClick(btn.el, () => {
        const name = btn.el.dataset.name ?? 'Product';
        cart.addToCart({ id: `${name.toLowerCase()}-${Date.now()}`, name, price: 0 });
      });
    }

    // Island B — reactive summary
    getElement('#cart-total').text(cart.cartTotal);

    const cartList = getElement<HTMLUListElement>('#cart-list');
    cart.cartItems.subscribe(items => {
      cartList.el.innerHTML = items
        .map(item => `<li class="text-sm opacity-70 py-1 border-b border-theme">${item.name}</li>`)
        .join('');
    });

    onClick('#btn-clear', () => cart.clearCart());
    */
  </script>
</BaseLayout>