---
// apps/demo/src/pages/approaches.astro
---
<html lang="en">
  <head><meta charset="utf-8" /><title>Both approaches</title></head>
  <body>
    <nav>
      <ul>
        <li><a href="/">Counter service</a></li>
        <li><a href="/approaches">Attributes + Elements approaches</a></li>
        <li><a href="/elements-demo">Elements demo (ShopService)</a></li>
        <li><a href="/dom-demo">DOM demo (getElement)</a></li>
      </ul>
    </nav>
    <h2>Attributes approach</h2>
    <p dx-show="hasItems">You have items in your cart</p>
    <button dx-if="isLoggedIn">My account</button>
    <ul>
      <li dx-for="cartItems" dx-text="name"></li>
    </ul>

    <h2>Elements approach</h2>
    <dx-show signal="hasItems">
      <p>You have items in your cart</p>
    </dx-show>

    <dx-if signal="isLoggedIn">
      <button>My account</button>
    </dx-if>

    <ul>
      <dx-for signal="cartItems">
        <li dx-text="name"></li>
      </dx-for>
    </ul>

    <button id="btn-add">Add item</button>
    <button id="btn-login">Toggle login</button>

    <script>
      import { signal, computed } from '@astro-dx/core';
      import { register, bootstrap } from '@astro-dx/attributes';
      import '@astro-dx/elements';
      import { on } from '@astro-dx/events';

      const cartItems = signal<{ name: string }[]>([]);
      const isLoggedIn = signal(false);
      const hasItems = computed(() => cartItems().length > 0);

      register({ cartItems, isLoggedIn, hasItems });
      bootstrap();

      let i = 0;
      on('#btn-add', 'click', () => {
        i++;
        cartItems.update((prev) => [...prev, { name: `Item ${i}` }]);
      });

      on('#btn-login', 'click', () => {
        isLoggedIn.update((v) => !v);
      });
    </script>
  </body>
</html>
