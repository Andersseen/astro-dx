---
import CodeBlock from '../../components/CodeBlock.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="@astro-dx/core">
  <section and-layout="vertical gap:xl" class="max-w-3xl mx-auto px-6 py-24">

    <div and-layout="vertical gap:sm">
      <and-badge variant="outline" class="w-fit">Docs · @astro-dx/core</and-badge>
      <h1 and-text="h2 weight:bold">@astro-dx/core</h1>
      <p and-text="p" class="opacity-70">
        Reactive primitives — signal, computed, effect — and lifecycle hooks for ViewTransitions.
      </p>
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">signal()</h2>
      <CodeBlock lang="typescript" code={`
import { signal } from '@astro-dx/core';

const count = signal(0);

count();           
count.set(5);      
count.update(v => v + 1);  
count.subscribe(v => console.log(v)); 
      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">computed()</h2>
      <CodeBlock lang="typescript" code={`
import { signal, computed } from '@astro-dx/core';

const count = signal(0);
const double = computed(() => count() * 2);

double();  
count.set(3);
double();  
      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">effect()</h2>
      <CodeBlock lang="typescript" code={`
import { signal, effect } from '@astro-dx/core';

const count = signal(0);
const stop = effect(() => {
});


      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">onPageLoad() / onBeforeSwap()</h2>
      <p and-text="p-sm" class="opacity-70">
        Lifecycle hooks for Astro ViewTransitions. Fall back gracefully without ViewTransitions.
      </p>
      <CodeBlock lang="typescript" code={`
import { onPageLoad, onBeforeSwap } from '@astro-dx/core';
import { getElement, destroyAll } from '@astro-dx/dom';

onPageLoad(() => {
  
  const btn = getElement('#btn');
  btn.on('click', () => {  });
});

onBeforeSwap(() => {
  
  destroyAll(); 
});
      `} />
    </div>

  </section>
</BaseLayout>
