---
import CodeBlock from '../../components/CodeBlock.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="@astro-dx/elements">
  <section and-layout="vertical gap:xl" class="max-w-3xl mx-auto px-6 py-24">

    <div and-layout="vertical gap:sm">
      <and-badge variant="outline" class="w-fit">Docs · @astro-dx/elements</and-badge>
      <h1 and-text="h2 weight:bold">@astro-dx/elements</h1>
      <p and-text="p" class="opacity-70">
        dx-if, dx-show, dx-for as custom elements — self-documenting, no attribute pollution.
      </p>
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">Setup</h2>
      <CodeBlock lang="typescript" code={`
import { register } from '@astro-dx/elements';
import '@astro-dx/elements'; 

import { signal } from '@astro-dx/core';

const isOpen = signal(false);
const items  = signal<{ name: string; price: number }[]>([]);

register({ isOpen, items });
      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">dx-show</h2>
      <CodeBlock lang="html" code={`
<dx-show signal="isOpen">
  <p>Visible when isOpen is truthy. Stays in DOM.</p>
</dx-show>
      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">dx-if</h2>
      <CodeBlock lang="html" code={`
<dx-if signal="isOpen">
  <div>Created when truthy, destroyed when falsy.</div>
</dx-if>
      `} />
    </div>

    <div and-layout="vertical gap:sm">
      <h2 and-text="h5 weight:bold">dx-for</h2>
      <CodeBlock lang="html" code={`
<ul>
  <dx-for signal="items">
    <li>
      <span dx-text="name"></span>
      <span dx-text="price"></span>
    </li>
  </dx-for>
</ul>
      `} />
    </div>

    <and-alert variant="info">
      Use <code>@astro-dx/attributes</code> if you prefer decorating existing elements
      rather than wrapping with custom element tags.
    </and-alert>

  </section>
</BaseLayout>
