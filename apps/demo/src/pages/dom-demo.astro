---
// apps/demo/src/pages/dom-demo.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>@astro-dx/dom demo</title>
  </head>
  <body>
    <h2>Modal</h2>
    <button id="btn-open">Open modal</button>

    <dialog id="modal">
      <h2 id="modal-title">Default title</h2>
      <p id="modal-body">Content here</p>
      <button id="btn-close">Close</button>
    </dialog>

    <h2>Product list</h2>
    <ul id="products">
      <li class="product-item" data-id="1">Product 1</li>
      <li class="product-item" data-id="2">Product 2</li>
      <li class="product-item" data-id="3">Product 3</li>
    </ul>

    <p>Last clicked: <span id="last-clicked">none</span></p>

    <script>
      import { signal, onPageLoad, onBeforeSwap } from '@astro-dx/core';
      import { getElement, getElements, destroyAll } from '@astro-dx/dom';

      onPageLoad(() => {
        const isOpen = signal(false);
        const modalTitle = signal('Hello from astro-dx');
        const lastClicked = signal('none');

        const modal = getElement<HTMLDialogElement>('#modal');
        const btnOpen = getElement<HTMLButtonElement>('#btn-open');
        const btnClose = getElement<HTMLButtonElement>('#btn-close');
        const title = getElement<HTMLHeadingElement>('#modal-title');
        const lastEl = getElement<HTMLSpanElement>('#last-clicked');

        title.text(modalTitle);
        lastEl.text(lastClicked);

        btnOpen.on('click', () => isOpen.set(true));
        btnClose.on('click', () => isOpen.set(false));
        modal.on('close', () => isOpen.set(false));

        modal.effect(() => {
          if (isOpen()) {
            if (!modal.el.open) {
              modal.el.showModal();
            }
          } else if (modal.el.open) {
            modal.el.close();
          }
        });

        const items = getElements<HTMLLIElement>('.product-item');
        for (const item of items) {
          item
            .onHover({
              enter: () => item.el.style.setProperty('opacity', '0.7'),
              leave: () => item.el.style.removeProperty('opacity'),
            })
            .on('click', () => {
              lastClicked.set(item.el.dataset.id ?? 'unknown');
            });
        }
      });

      onBeforeSwap(() => {
        destroyAll();
      });
    </script>
  </body>
</html>
