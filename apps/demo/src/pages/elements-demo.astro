---
// apps/demo/src/pages/elements-demo.astro
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>astro-dx-elements demo</title>
  </head>
  <body>
    <nav>
      <ul>
        <li><a href="/">Counter service</a></li>
        <li><a href="/approaches">Attributes + Elements approaches</a></li>
        <li><a href="/elements-demo">Elements demo (ShopService)</a></li>
        <li><a href="/dom-demo">DOM demo (getElement)</a></li>
      </ul>
    </nav>

    <h1>astro-dx-elements</h1>

    <!-- dx-show: node stays in DOM, toggled with hidden attribute -->
    <dx-show signal="hasItems">
      <p>You have items in your cart</p>
    </dx-show>

    <!-- dx-if: node is created/destroyed -->
    <dx-if signal="isModalOpen">
      <div class="modal">
        <p>Modal content</p>
        <button id="btn-close">Close</button>
      </div>
    </dx-if>

    <!-- dx-for: renders a list reactively -->
    <ul>
      <dx-for signal="cartItems">
        <li>
          <span dx-text="name"></span>
          &mdash;
          <span dx-text="price"></span>
        </li>
      </dx-for>
    </ul>

    <button id="btn-add">Add product</button>
    <button id="btn-open">Open modal</button>
    <button id="btn-clear">Clear cart</button>

    <script>
      import { register } from '@astro-dx/elements';
      import '@astro-dx/elements';
      import { on } from '@astro-dx/events';
      import { ShopService } from '../services/shop.service';

      register({
        hasItems: ShopService.hasItems,
        isModalOpen: ShopService.isModalOpen,
        cartItems: ShopService.cartItems,
      });

      let i = 0;
      on('#btn-add', 'click', () => {
        i++;
        ShopService.addToCart({ id: `p${i}`, name: `Product ${i}`, price: i * 10 });
      });

      on('#btn-open', 'click', () => ShopService.openModal());
      on(document, 'click', (event) => {
        if (event instanceof Event && event.target instanceof HTMLElement) {
          if (event.target.id === 'btn-close') {
            ShopService.closeModal();
          }
        }
      });
      on('#btn-clear', 'click', () => ShopService.clearCart());
    </script>

  </body>
</html>
