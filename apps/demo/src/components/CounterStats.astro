---
// apps/demo/src/components/CounterStats.astro
// Separate island - reads the same service, no props passed
---
<div id="stats">
  Double: <span id="double-value">0</span>
</div>

<script>
  import { CounterService } from '../services/counter.service';
  import { effect } from '@astro-dx/core';

  const doubleEl = document.querySelector('#double-value');
  if (doubleEl) {
    effect(() => {
      doubleEl.textContent = String(CounterService.double());
    });
  }
</script>