---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { id: 'home', label: 'Home', href: '/' },
  { id: 'demos', label: 'Demos', href: '/demo' },
  { id: 'playground', label: 'Playground', href: '/playground' },
  { id: 'docs', label: 'Docs', href: '/docs' },
  { id: 'libraries', label: 'Libraries', href: '/libs' },
  { id: 'about', label: 'About', href: '/about' },
] as const;

const activeItem =
  navItems.find((item) =>
    item.href === '/'
      ? currentPath === '/'
      : currentPath === item.href || currentPath.startsWith(`${item.href}/`),
  )?.id ?? 'home';
---
<header class="sticky top-0 z-50 border-b border-theme backdrop-blur-xl">
  <and-navbar
    data-app-navbar
    variant="default"
 position="fixed"
    
    items={JSON.stringify(navItems)}
    active-item={activeItem}
    aria-nav-label="Main navigation"
    custom-class="w-full"
  >
      <and-icon
        slot="toggle-icon"
        data-navbar-toggle-icon
        name="menu"
        size="24"
      ></and-icon>

      <a slot="brand" href="/" class="inline-flex items-center gap-2 no-underline">
        <and-icon name="rocket" size="16"></and-icon>
        <span class="font-semibold tracking-[0.02em]">astro-dx</span>
      </a>
  <div slot="actions">
  
    <and-button size="sm" variant="link" href="https://github.com/Andersseen/astro-dx" target="_blank">
      <and-icon name="github" size="16"></and-icon>
      GitHub
    </and-button>
 

  </and-navbar>

</header>