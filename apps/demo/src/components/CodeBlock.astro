---
// Uses Astro's built-in syntax highlighting
// biome-ignore lint/correctness/noUnusedVariables: Astro Props interface is used by the framework
interface Props {
  code: string;
  lang?: string;
}
// biome-ignore lint/correctness/noUnusedVariables: used in template below
const { code, lang = 'typescript' } = Astro.props;
---
<div class="overflow-hidden rounded-xl border border-white/10 bg-slate-950/60 text-sm shadow-sm">
  <div class="border-b border-white/10 bg-slate-900/70 px-4 py-2">
    <span and-text="p-sm" class="font-mono uppercase tracking-wide text-slate-400">{lang}</span>
  </div>
  <pre class="overflow-x-auto p-4 text-[13px] leading-6 text-slate-100"><code>{code.trim()}</code></pre>
</div>
