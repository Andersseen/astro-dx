---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<and-card class="w-full overflow-hidden">
  <div class="px-4 py-3 border-b border-theme surface-theme">
    <span and-text="p-sm weight:bold" class="opacity-60 uppercase tracking-wider text-xs">
      {title}
    </span>
  </div>
  <slot />
</and-card>
